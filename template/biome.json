{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "comment": "Biome config (recommended JS/TS linter + formatter). Sane defaults; tune per project.",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
