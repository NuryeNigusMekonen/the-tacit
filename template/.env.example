# Example config - variable NAMES only, never real values (Standard §3).
# Copy to .env for local dev. .env is git-ignored and must never be committed.
# Production secrets live in a secrets store, injected at deploy time.

# Examples (replace with your project's variables):
DATABASE_URL=
API_BASE_URL=
# THIRD_PARTY_API_KEY=   # set in the environment, not here
